{
  "hosting": {
    "public": "public",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/storyboard/**",
        "destination": "/storyboard/index.html"
      },
      {
        "source": "/workout-app/**",
        "destination": "/workout-app/index.html"
      }
    ]
  },
  "firestore": {
    "rules": "firestore.rules"
  }
}
